# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Any current Groq-hosted model works; this one is fast + high quality for email writing
GROQ_MODEL=llama-3.3-70b-versatile

# Only needed if you move off the default local sqlite file
DATABASE_URL=sqlite:///./data/emails.db

# Used by the Streamlit frontend to reach the FastAPI backend
BACKEND_URL=http://localhost:8000

# Comma-separated origins allowed to call the API (add your deployed Streamlit URL here)
ALLOWED_ORIGINS=http://localhost:8501

# Requests per minute per IP on /api/generate and /api/refine
RATE_LIMIT=15/minute

LOG_LEVEL=INFO
